#!/bin/bash
# Configuration file for OpenNotebook AWS deployment
# Run from AWS Cloud9 - credentials are automatic via IAM role
# Edit this file before running deploy.sh

# AWS Configuration
AWS_REGION=us-east-1
KEY_PAIR_NAME=my-key-pair  # Must exist in your AWS account in this region

# EC2 Instance Types
NOTEBOOK_INSTANCE_TYPE=t3.medium
OLLAMA_INSTANCE_TYPE=t3.large

# Storage
NOTEBOOK_VOLUME_SIZE=50  # GB
OLLAMA_VOLUME_SIZE=30    # GB

# OpenNotebook Configuration
ENCRYPTION_KEY=change-me-to-a-secret-random-string-at-least-32-chars

# Optional: Set LLM API keys here or configure them later via UI
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk-...
# GOOGLE_API_KEY=...

# Ollama Model (can be changed later)
OLLAMA_MODEL=nomic-embed-text

# Tags for your resources (for cost tracking)
ENVIRONMENT_TAG=dev
PROJECT_TAG=open-notebook
